rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles & Game Data
    match /users/{userId} {
      // Allow reading if:
      // 1. It is the user's own profile.
      // 2. The profile is marked as public (allows guests to see leaderboards).
      allow read: if (request.auth != null && request.auth.uid == userId) || resource.data.get('isPublic', false) == true;
      
      // RESTRICTED WRITE:
      // We allow the client to save progress and settings, 
      // but NOT competitive stats (RP, Streak, History).
      // Competitive stats can ONLY be updated by the Cloud Function (Admin).
      allow create: if request.auth != null && request.auth.uid == userId 
                    && (request.resource.data.get('schemaVersion', 0) >= 7)
                    && !request.resource.data.keys().hasAny(['currentStreak', 'wins', 'history', 'dailyRP', 'monthlyRP', 'totalRP']);
      
      allow update: if request.auth != null && request.auth.uid == userId 
                    && (
                      // 1. MIGRACIÓN: Permitir todo si se está elevando al Esquema v7.1 híbrido
                      (resource.data.get('schemaVersion', 0) < 7.1 && request.resource.data.get('schemaVersion', 0) >= 7.1)
                      ||
                      // 2. SEGURIDAD V7.1: Lista blanca de campos permitidos para la App
                      (resource.data.get('schemaVersion', 0) >= 7.1 && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['schemaVersion', 'username', 'username_lc', 'dailyRP', 'monthlyRP', 'totalRP', 'isPublic', 'stats', 'progress', 'lastUpdated', 'lastDailyUpdate', 'lastMonthlyUpdate', 'lastLocalUpdate', 'registeredAt', 'isVerified', 'activeSessionId']))
                    );
      
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // Sub-colección de Historial (v5)
      match /history/{seed} {
        allow read: if (request.auth != null && request.auth.uid == userId) || get(/databases/$(database)/documents/users/$(userId)).data.isPublic == true;
        allow create, update: if request.auth != null && request.auth.uid == userId; 
        allow delete: if request.auth != null && request.auth.uid == userId; 
      }

      // Sessions for the Referee (Internal use)
      match /sessions/{sessionId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create, update: if false; 
      }
    }

    // Public Leaderboards (Read only for everyone)
    match /leaderboards/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // Global Config / Puzzles
    match /puzzles/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
