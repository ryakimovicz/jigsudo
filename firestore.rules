rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is the Admin (Roman/Corolado)
    function isAdmin() {
      return request.auth != null && (request.auth.uid == 'SR5GIs3WdpXl6HkmRxhHh4Slg283');
    }

    // GLOBAL ADMIN OVERRIDE: Admin can read/write everything
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // User Profiles & Game Data
    match /users/{userId} {
      // MASTER ADMIN ACCESS: 
      // Always allowed, independent of document data, enabling aggregations (count)
      allow read, write: if isAdmin();

      // Regular User & Public visibility
      allow read: if (request.auth != null && request.auth.uid == userId)
                    || resource.data.get('isPublic', false) == true;
      
      // RESTRICTED WRITE for regular users:
      allow create: if request.auth != null && request.auth.uid == userId 
                    && (request.resource.data.get('schemaVersion', 0) >= 7)
                    && !request.resource.data.keys().hasAny(['currentStreak', 'wins', 'history', 'dailyRP', 'monthlyRP', 'totalRP']);
      
      allow update: if request.auth != null && request.auth.uid == userId 
                    && (
                      (resource.data.get('schemaVersion', 0) < 7.1 && request.resource.data.get('schemaVersion', 0) >= 7.1)
                      ||
                      (resource.data.get('schemaVersion', 0) >= 7.1 && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['schemaVersion', 'username', 'username_lc', 'dailyRP', 'monthlyRP', 'totalRP', 'isPublic', 'stats', 'progress', 'lastUpdated', 'lastDailyUpdate', 'lastMonthlyUpdate', 'lastLocalUpdate', 'registeredAt', 'isVerified', 'activeSessionId', 'totalPenaltyAccumulated', 'monthlyPenaltyAccumulated', 'currentRP']))
                    );
      
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // Sub-colección de Historial (v5)
      match /history/{seed} {
        allow read: if (request.auth != null && request.auth.uid == userId) 
                     || get(/databases/$(database)/documents/users/$(userId)).data.isPublic == true;
        allow create, update: if request.auth != null && request.auth.uid == userId; 
        allow delete: if request.auth != null && request.auth.uid == userId; 
      }

      // Sessions for the Referee (Internal use)
      match /sessions/{sessionId} {
        allow read, delete: if (request.auth != null && request.auth.uid == userId);
        allow create, update: if false; 
      }
    }

    // Public Collections
    match /leaderboards/{document=**} {
      allow read: if true;
    }
    
    match /puzzles/{document=**} {
      allow read: if true;
    }

    // Administrative Reports (v1.6.0)
    match /referee_reports/{reportId} {
      allow create: if request.auth != null;
    }
  }
}
